# ─── Site ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase ───
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Sport APIs (optional – Fallback-Daten greifen sonst) ───
# https://www.thesportsdb.com/api.php – Free-Key "3" funktioniert out-of-the-box
THESPORTSDB_API_KEY=3
NEXT_PUBLIC_THESPORTSDB_KEY=3
# https://www.football-data.org/
FOOTBALL_DATA_API_KEY=

# ─── Cron / Refresh Schutz ───
CRON_SECRET=generate_a_long_random_string

# ─── OneSignal Web Push (optional) ───
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
NEXT_PUBLIC_ONESIGNAL_APP_ID=
